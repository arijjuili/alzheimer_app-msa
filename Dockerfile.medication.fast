FROM eclipse-temurin:17-jre
RUN apt-get update && apt-get install -y curl
WORKDIR /app
RUN groupadd -r medication && useradd -r -g medication -m medication
COPY services/medication/target/medication-0.0.1-SNAPSHOT.jar app.jar
RUN chown -R medication:medication /app
USER medication
EXPOSE 8083
HEALTHCHECK --interval=30s --timeout=10s --start-period=60s --retries=3 CMD curl -f http://localhost:8083/actuator/health || exit 1
ENTRYPOINT ["sh", "-c", "java $JAVA_OPTS -jar app.jar"]
